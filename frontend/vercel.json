{
    "buildCommand": "npm install && npm run build",
    "outputDirectory": "dist",
    "framework": "vite",
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "http://3.36.149.255:5000/api/:path*"
        },
        {
            "source": "/uploads/:path*",
            "destination": "http://3.36.149.255:5000/uploads/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}